{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
      "read": "allow",
      "edit": "allow",
      "grep": "allow",
      "glob": "allow",
      "list": "allow",
      "question": "allow",
      "todowrite": "allow",
      "todoread": "allow",
      "bash": "ask",
      "webfetch": "ask",
      "lsp": "allow"
  },
  "lsp": {
    "kotlin": {
      "command": [
        "/opt/kotlin-lsp/server/bin/kotlin-language-server"
      ],
      "extensions": [".kt", ".kts"]
    }
  }
}
